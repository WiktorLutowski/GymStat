<UserControl
    x:Class="GymStat.Views.ExerciseFormView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:GymStat.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:GymStat.ViewModels"
    d:Background="White"
    d:DataContext="{d:DesignInstance vm:ExerciseFormViewModel}"
    d:DesignHeight="700"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <conv:IndexToSeriesConverter x:Key="IndexToSeriesConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <Button
            Grid.Row="0"
            Grid.Column="0"
            Margin="20,10,10,10"
            Padding="10"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Command="{Binding BackCommand}"
            Content="Cofnij"
            FontSize="15" />

        <TextBlock
            Grid.ColumnSpan="2"
            Margin="10"
            HorizontalAlignment="Center"
            FontSize="30"
            FontWeight="Bold"
            Text="Dodaj / Edytuj ćwiczenie" />

        <StackPanel
            Grid.Row="1"
            Grid.ColumnSpan="2"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <TextBlock
                Margin="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="15"
                Text="Ćwiczenie: " />

            <ComboBox
                Width="200"
                VerticalAlignment="Center"
                VerticalContentAlignment="Center"
                FontSize="15"
                ItemsSource="{Binding Exercises}"
                SelectedItem="{Binding SelectedExercise}" />

        </StackPanel>

        <Button
            Grid.Row="2"
            Grid.Column="1"
            Margin="20"
            Padding="10"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Command="{Binding AddSetCommand}"
            Content="Dodaj serie"
            FontSize="15" />

        <ItemsControl
            Grid.Row="2"
            Margin="20"
            AlternationCount="9999"
            ItemsSource="{Binding Sets}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,5" Orientation="Horizontal">
                        <TextBlock
                            Width="30"
                            VerticalAlignment="Center"
                            FontSize="15"
                            FontWeight="Bold"
                            Text="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, Converter={StaticResource IndexToSeriesConverter}}" />

                        <TextBox
                            Width="60"
                            Margin="5,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            DataObject.Pasting="TextBox_Pasting"
                            FontSize="15"
                            PreviewTextInput="NumberValidationTextBox"
                            Text="{Binding Weight}" />
                        <TextBlock VerticalAlignment="Center" Text="kg" />

                        <TextBox
                            Width="50"
                            Margin="15,0,5,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            DataObject.Pasting="TextBox_Pasting"
                            FontSize="15"
                            PreviewTextInput="NumberValidationTextBox"
                            Text="{Binding Repetitions}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="15"
                            Text="powt." />

                        <Button
                            Grid.Row="1"
                            Width="30"
                            Command="{Binding DataContext.RemoveSetCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}"
                            CommandParameter="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, Converter={StaticResource IndexToSeriesConverter}}"
                            Style="{StaticResource InvisibleIconButton}"
                            Tag="/Images/remove-icon.png" />
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Button
            Grid.Row="3"
            Grid.ColumnSpan="2"
            Margin="10"
            Padding="10"
            HorizontalAlignment="Center"
            Command="{Binding AddResultCommand}"
            Content="Dodaj / Edytuj ćwiczenie"
            FontSize="15" />
    </Grid>
</UserControl>
